# AI QA System V3 - Environment Variables

# App
APP_ENV=production
DEBUG=false

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/ai_qa

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15

# LLM API Keys (LiteLLM)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx

# Model Configuration
PRIMARY_MODEL=anthropic/claude-sonnet-4-20250514
SECONDARY_MODEL=openai/gpt-4o
FALLBACK_MODEL=deepseek/deepseek-chat
MAX_BUDGET_MONTHLY=100.0

# RAG
RAG_WORKING_DIR=./data/rag
EMBEDDING_MODEL=text-embedding-3-small

# Monitoring
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_METRICS=true
GRAFANA_PASSWORD=admin
